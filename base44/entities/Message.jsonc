{
  "name": "Message",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "resolved"
      ],
      "default": "open"
    },
    "user_id": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "email",
    "message"
  ]
}